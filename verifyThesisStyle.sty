%% Chapter  (titlesec display style)
%
% Design: two stacked rules above the chapter label, a single rule below it,
% then the chapter title in Huge sffamily — all centered, monochrome.
%
% titlesec is loaded below; \titleformat{\chapter} supersedes memoir's
% \makechapterstyle mechanism, so no \makechapterstyle call is needed.


%% Lower level sections  (titlesec — overrides memoir's \setsecheadstyle family)
% Note: titlesec redefines \@startsection and therefore supersedes memoir's
% \setsecheadstyle / \setsubsecheadstyle etc.  Those commands are intentionally
% not used here.
\RequirePackage{titlesec}

% ------------------------------------------------------------------
%  \chapter  — centered display, double rule / single rule sandwich
% ------------------------------------------------------------------
\titleformat{\chapter}[display]
  {\normalfont\Large\filcenter\sffamily}
  {%
    \titlerule%
    \vspace{2pt}%
    \titlerule
    \vspace{1pc}%
    \large\MakeUppercase{\chaptertitlename}\ \thechapter
  }
  {1pc}
  {%
    \titlerule%
    \vspace{2pt}%
    \titlerule
    \vspace{1pc}%
    \Huge\bfseries\boldmath
  }

\titlespacing*{\chapter}
  {0pt}
  {2pc}
  {3pc}

% ------------------------------------------------------------------
%  \section  — large bold sffamily, black number, thin gray rule below
% ------------------------------------------------------------------
\titleformat{\section}
  [block]
  {\Large\bfseries\boldmath\sffamily}
  {\thesection}
  {1em}
  {}
  [\vspace{3pt}{\color{black!35}\titlerule[0.6pt]}]

\titlespacing*{\section}
  {0pt}
  {2.8ex plus 1ex minus .2ex}
  {1.5ex plus .3ex}

% ------------------------------------------------------------------
%  \subsection  — medium bold sffamily, black number, very faint rule
% ------------------------------------------------------------------
\titleformat{\subsection}
  [block]
  {\large\bfseries\boldmath\sffamily}
  {\thesubsection}
  {1em}
  {}
  [\vspace{2pt}{\color{black!20}\titlerule[0.4pt]}]

\titlespacing*{\subsection}
  {0pt}
  {2.2ex plus .8ex minus .2ex}
  {1ex plus .2ex}

% ------------------------------------------------------------------
%  \subsubsection  — normal bold sffamily, black number, no rule
% ------------------------------------------------------------------
\titleformat{\subsubsection}
  [block]
  {\normalsize\bfseries\sffamily}
  {\thesubsubsection}
  {1em}
  {}

\titlespacing*{\subsubsection}
  {0pt}
  {1.8ex plus .5ex minus .2ex}
  {0.6ex plus .1ex}

% ------------------------------------------------------------------
%  \paragraph  — run-in, bold sffamily, no number, ends with em-dash
% ------------------------------------------------------------------
\titleformat{\paragraph}
  [runin]
  {\normalsize\bfseries\sffamily}
  {}
  {0em}
  {}
  [\enspace---\enspace]

\titlespacing*{\paragraph}
  {0pt}
  {1.2ex plus .4ex minus .2ex}
  {0pt}


